#!/usr/bin/env bash

THEMES_DIR="$HOME/dotfiles/themes"

wallpaper="$1"
mode="dark"

case "$2" in
--mode)
  mode="$3"
  ;;
esac

if [[ ! -d "$THEMES_DIR/matugen" ]]; then
  mkdir -p "$THEMES_DIR/matugen"
  ln -nsf "$HOME/dotfiles/wallpapers" "$THEMES_DIR/matugen/wallpapers"
fi
matugen --source-color-index 0 image "$wallpaper" -m "$mode"
